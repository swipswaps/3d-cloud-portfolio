<!DOCTYPE html>
<html>
<head>
    <title>3D Code Portfolio – SwipSwaps</title>
    <style>
        body { margin: 0; overflow: hidden; font-family: monospace; user-select: none; }
        canvas { display: block; }
        #debug-panel {
            position: fixed; bottom: 20px; left: 20px; width: 400px; max-height: 250px;
            background: rgba(0,0,0,0.85); border-radius: 8px; padding: 10px;
            font-size: 10px; font-family: monospace; color: #0f0; overflow-y: auto;
            z-index: 100; display: none;
        }
        #debug-toggle {
            position: fixed; bottom: 20px; left: 20px; z-index: 101;
            background: #0a0a14; border: 1px solid #5effe0; border-radius: 20px;
            padding: 4px 10px; cursor: pointer; color: #5effe0;
            font-family: monospace; font-size: 10px;
        }
    </style>
</head>
<body>
    <div id="info">🔮 3D Repository Cloud<br><span style="font-size: 10px;">Click: lock | Double-click: open GitHub</span></div>
    <div class="instruction">✨ Drag to rotate | Scroll to zoom</div>

    <!-- Search Bar -->
    <div style="position: fixed; top: 20px; left: 20px; right: 20px; z-index: 100; background: rgba(0,0,0,0.8); padding: 15px; border-radius: 60px;">
        <div style="display: flex; gap: 12px; align-items: center;">
            <input type="text" id="searchInput" placeholder="🔎 Search..." style="flex:2; background:transparent; border:none; color:white; padding:12px;">
            <select id="searchMode" style="background:#1a1a2e; color:white; border-radius:30px; padding:8px 16px;">
                <option value="readme">📄 Search READMEs (local)</option>
                <option value="github">🔍 Search code (GitHub API)</option>
                <option value="semantic">🧠 Semantic Search</option>
                <option value="token">🔑 Set GitHub Token</option>
            </select>
            <button id="searchBtn" style="background:#2e7d64; border-radius:50%; width:44px; height:44px;">🔍</button>
        </div>
    </div>

    <button id="debug-toggle">[+] Logs</button>
    <div id="debug-panel"></div>
    <div style="position: fixed; bottom: 20px; right: 20px; display: flex; gap: 10px; z-index: 200;">
        <div style="background:#2e7d64; padding:8px 16px; border-radius:20px; cursor:pointer;" onclick="window.open('/api/export/slop?format=json','_blank')">📊 JSON</div>
        <div style="background:#2e7d64; padding:8px 16px; border-radius:20px; cursor:pointer;" onclick="window.open('/api/export/slop?format=csv','_blank')">📈 CSV</div>
    </div>

    <script type="module">
        // Global logging function
        window.logToDebug = function(msg) {
            const timestamp = new Date().toLocaleTimeString();
            const logMsg = `[${timestamp}] 🐞 ${msg}`;
            console.log(logMsg);
            const panel = document.getElementById('debug-panel');
            if (panel) {
                panel.innerHTML += `<div>${logMsg}</div>`;
                panel.scrollTop = panel.scrollHeight;
            }
        };
        
        // Toggle debug panel
        document.getElementById('debug-toggle').onclick = () => {
            const panel = document.getElementById('debug-panel');
            const btn = document.getElementById('debug-toggle');
            if (panel.style.display === 'none') {
                panel.style.display = 'block';
                btn.textContent = '[-] Logs';
            } else {
                panel.style.display = 'none';
                btn.textContent = '[+] Logs';
            }
        };
        
        window.logToDebug('🚀 Starting application');
        window.logToDebug('🧠 Initializing Three.js');
        
        import * as THREE from 'https://cdn.skypack.dev/three@0.128.0/build/three.module.js';
        import { OrbitControls } from 'https://cdn.skypack.dev/three@0.128.0/examples/jsm/controls/OrbitControls.js';
        import { CSS2DRenderer, CSS2DObject } from 'https://cdn.skypack.dev/three@0.128.0/examples/jsm/renderers/CSS2DRenderer.js';
        
        const scene = new THREE.Scene();
        scene.background = new THREE.Color(0x050510);
        scene.fog = new THREE.FogExp2(0x050510, 0.008);
        
        const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
        camera.position.set(15, 10, 20);
        
        const renderer = new THREE.WebGLRenderer({ antialias: true });
        renderer.setSize(window.innerWidth, window.innerHeight);
        document.body.appendChild(renderer.domElement);
        
        const labelRenderer = new CSS2DRenderer();
        labelRenderer.setSize(window.innerWidth, window.innerHeight);
        labelRenderer.domElement.style.position = 'absolute';
        labelRenderer.domElement.style.top = '0px';
        labelRenderer.domElement.style.left = '0px';
        labelRenderer.domElement.style.pointerEvents = 'none';
        document.body.appendChild(labelRenderer.domElement);
        
        const controls = new OrbitControls(camera, renderer.domElement);
        controls.enableDamping = true;
        controls.autoRotate = true;
        controls.autoRotateSpeed = 1.0;
        
        // Drag logging
        controls.addEventListener('start', () => window.logToDebug('🖱️ DRAG START - Rotating cloud'));
        controls.addEventListener('end', () => window.logToDebug('🖱️ DRAG END - Rotation complete'));
        
        window.logToDebug('✅ Three.js scene initialized');
        
        let repos = [];
        let cloudGroup = new THREE.Group();
        scene.add(cloudGroup);
        
        function lockRepository(name) {
            window.logToDebug(`🔒 Locked: ${name}`);
        }
        
        async function loadRepos() {
            try {
                const res = await fetch('/api/repos');
                const data = await res.json();
                repos = data.repos || [];
                window.logToDebug(`✅ Loaded ${repos.length} repos from backend`);
                
                repos.forEach(repo => {
                    const geometry = new THREE.SphereGeometry(0.4, 16, 16);
                    const material = new THREE.MeshStandardMaterial({ color: 0x5effe0 });
                    const sphere = new THREE.Mesh(geometry, material);
                    
                    const phi = Math.acos(2 * Math.random() - 1);
                    const theta = 2 * Math.PI * Math.random();
                    const radius = 8;
                    sphere.position.x = radius * Math.sin(phi) * Math.cos(theta);
                    sphere.position.y = radius * Math.sin(phi) * Math.sin(theta);
                    sphere.position.z = radius * Math.cos(phi);
                    sphere.userData = { name: repo.name };
                    
                    const div = document.createElement('div');
                    div.textContent = repo.name.length > 25 ? repo.name.substring(0, 22) + '...' : repo.name;
                    div.style.cssText = 'color:#5effe0;font-size:12px;font-family:monospace;background:rgba(0,0,0,0.7);padding:4px 8px;border-radius:20px;border:1px solid #5effe0;cursor:pointer;white-space:nowrap;';
                    
                    div.onclick = (function(n) {
                        return function() {
                            window.logToDebug(`🖱️ CLICK - Repository: ${n}`);
                            lockRepository(n);
                        };
                    })(repo.name);
                    
                    div.ondblclick = (function(n) {
                        return function() {
                            window.logToDebug(`🖱️ DOUBLE CLICK - Opening: ${n}`);
                            window.open(`https://github.com/swipswaps/${n}`, '_blank');
                        };
                    })(repo.name);
                    
                    div.onmouseenter = (function(n) {
                        return function() {
                            window.logToDebug(`🖱️ HOVER - ${n}`);
                        };
                    })(repo.name);
                    
                    const label = new CSS2DObject(div);
                    label.position.copy(sphere.position);
                    cloudGroup.add(sphere);
                    cloudGroup.add(label);
                });
                
                window.logToDebug(`🎨 Created ${repos.length} labels`);
            } catch(e) {
                window.logToDebug(`❌ Failed: ${e.message}`);
            }
        }
        
        loadRepos();
        
        function animate() {
            requestAnimationFrame(animate);
            controls.update();
            renderer.render(scene, camera);
            labelRenderer.render(scene, camera);
        }
        animate();
        
        window.logToDebug('🎨 App ready - Click spheres, drag cloud, hover for logs');
    </script>

<script>
// Throttled logging - prevents crash
let logCount = 0;
let logResetTime = Date.now();
let logBuffer = [];

window.safeLog = function(msg) {
    const now = Date.now();
    if (now - logResetTime > 1000) {
        logCount = 0;
        logResetTime = now;
    }
    
    if (logCount < 10) {
        logCount++;
        const timestamp = new Date().toLocaleTimeString();
        const logMsg = `[${timestamp}] 🐞 ${msg}`;
        
        const panel = document.getElementById('debug-panel');
        if (panel) {
            const div = document.createElement('div');
            div.textContent = logMsg;
            panel.appendChild(div);
            panel.scrollTop = panel.scrollHeight;
        }
        console.log(logMsg);
    } else if (logCount === 10) {
        console.log('[THROTTLED] Additional logs suppressed');
    }
};

// Only log essential events
document.addEventListener('click', (e) => {
    const target = e.target.closest('[style*="cursor: pointer"]');
    if (target && target.textContent) {
        window.safeLog(`🖱️ CLICK - ${target.textContent.substring(0, 30)}`);
    }
});

// Log drag start/end only
let dragActive = false;
document.addEventListener('mousedown', () => { dragActive = true; });
document.addEventListener('mouseup', () => { 
    if (dragActive) {
        window.safeLog(`🖱️ DRAG END`);
        dragActive = false;
    }
});

window.safeLog('Throttled logging active - max 10 logs/sec');
</script>

</body>
</html>
