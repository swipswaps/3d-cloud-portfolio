<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, user-scalable=no, viewport-fit=cover">
    <title>3D Code Portfolio – SwipSwaps</title>
    <style>
        /* (all existing styles – unchanged) */
        body { margin: 0; overflow: hidden; font-family: monospace; user-select: none; touch-action: pan-x pan-y; }
        canvas { display: block; cursor: grab; touch-action: none; }
        canvas:active { cursor: grabbing; }
        @media (max-width: 768px) {
            #minimap-container { display: none !important; }
            button, .ctrl-row button, #ctrl-toggle, #debug-toggle { padding: 8px 16px !important; font-size: 14px !important; min-height: 44px; }
            .repo-label { font-size: 14px !important; white-space: normal !important; max-width: 120px; text-align: center; }
            #control-panel { width: 90%; left: 5%; right: 5%; bottom: 70px; }
            #ctrl-toggle { left: auto; right: 20px; bottom: 20px; }
        }
        @media (min-width: 769px) { #minimap-container { display: block; } }
        #debug-toggle, #ctrl-toggle, #minimap-container, #control-panel { transition: opacity 0.2s ease; }
        #debug-toggle { position: fixed; bottom:20px; left:20px; z-index:101; background:#0a0a14; border:1px solid #5effe0; border-radius:20px; padding:4px 12px; cursor:pointer; color:#5effe0; font-family:monospace; font-size:10px; }
        #debug-panel { position: fixed; bottom:20px; left:70px; width:500px; max-height:300px; background:rgba(0,0,0,0.85); border-radius:8px; padding:10px; font-size:10px; font-family:monospace; color:#0f0; overflow-y:auto; z-index:100; display:none; pointer-events:auto; user-select:text; }
        .instruction { position: absolute; bottom:20px; right:20px; color:#5effe0; background:rgba(0,0,0,0.5); padding:5px 10px; border-radius:5px; font-size:11px; pointer-events:none; }
        #info { position: absolute; top:20px; left:20px; color:white; background:rgba(0,0,0,0.6); padding:10px 15px; border-radius:8px; font-size:14px; backdrop-filter:blur(5px); pointer-events:none; }
        #minimap-container { position: fixed; bottom:20px; right:20px; width:180px; height:180px; background:rgba(0,0,0,0.7); border-radius:12px; border:1px solid #5effe0; z-index:200; pointer-events:none; box-shadow:0 0 10px rgba(0,0,0,0.5); }
        #minimap-container canvas { border-radius:12px; width:100%; height:100%; display:block; }
        #control-panel { position: fixed; bottom:20px; left:20px; width:260px; background:rgba(0,0,0,0.85); border-radius:12px; padding:10px; font-family:monospace; font-size:11px; color:#5effe0; border:1px solid #5effe0; z-index:102; backdrop-filter:blur(5px); pointer-events:auto; user-select:none; display:none; }
        #control-panel button, #control-panel select { background:#1a2a2a; border:1px solid #5effe0; color:#5effe0; border-radius:20px; padding:4px 8px; margin:2px; cursor:pointer; font-family:monospace; }
        #control-panel input { width:100px; margin-left:8px; vertical-align:middle; }
        .ctrl-row { margin:6px 0; display:flex; align-items:center; justify-content:space-between; }
        #ctrl-toggle { position:fixed; bottom:20px; left:300px; background:#0a0a14; border:1px solid #5effe0; border-radius:20px; padding:4px 12px; cursor:pointer; z-index:103; font-size:10px; color:#5effe0; }
        #readme-panel { position:fixed; top:20px; right:20px; width:300px; max-height:400px; background:rgba(0,0,0,0.9); border-radius:12px; border:1px solid #5effe0; z-index:150; pointer-events:auto; color:#ccc; font-size:12px; font-family:monospace; padding:10px; overflow-y:auto; display:none; backdrop-filter:blur(8px); }
        #close-readme { float:right; cursor:pointer; background:#333; padding:2px 8px; border-radius:10px; }
    </style>
    <script type="importmap">
        { "imports": { "three": "https://unpkg.com/three@0.128.0/build/three.module.js", "three/addons/": "https://unpkg.com/three@0.128.0/examples/jsm/" } }
    </script>
</head>
<body>
    <div id="info">🔮 3D Repository Cloud<br><span style="font-size:10px;">Click: README | Double-click: GitHub</span></div>
    <div class="instruction">✨ Drag to rotate | Pinch to zoom</div>
    <div style="position:fixed; top:20px; left:20px; right:20px; z-index:100; background:rgba(0,0,0,0.8); padding:12px; border-radius:60px;">
        <div style="display:flex; gap:10px; align-items:center; max-width:1200px; margin:0 auto; flex-wrap:wrap;">
            <input type="text" id="searchInput" placeholder="🔎 Filter spheres by name or description..." style="flex:2; background:transparent; border:none; color:white; padding:8px; min-width:120px;">
            <button id="clearBtn" style="background:#444; border-radius:30px; padding:6px 16px; color:white; cursor:pointer;">✖ Clear</button>
            <button id="searchBtn" style="background:#2e7d64; border-radius:30px; padding:6px 16px; color:white; cursor:pointer;">🔍 Filter</button>
            <button id="similarBtn" style="background:#2e7d64; border-radius:30px; padding:6px 16px; color:white; cursor:pointer;">🔗 Similar</button>
            <input type="text" id="fuzzySearchInput" placeholder="🔎 Fuzzy search (name, description, chat logs)" style="flex:2; background:transparent; border:1px solid #5effe0; color:white; padding:8px; min-width:150px;">
        </div>
    </div>
    <div id="minimap-container"><canvas id="minimap-canvas"></canvas></div>
    <div id="ctrl-toggle">🎮 Controls</div>
    <div id="control-panel">
        <div class="ctrl-row"><span>🔄 Auto-rotate</span><button id="toggleAutoRotate">ON</button></div>
        <div class="ctrl-row"><span>⚡ Damping</span><button id="toggleDamping">ON</button></div>
        <div class="ctrl-row"><span>📉 Damping factor</span><input type="range" id="dampingFactor" min="0.02" max="0.3" step="0.01" value="0.1"><span id="dampingVal">0.10</span></div>
        <div class="ctrl-row"><span>🐌 Rotate speed</span><input type="range" id="rotateSpeed" min="0.5" max="3.0" step="0.1" value="1.0"><span id="rotateVal">1.0</span></div>
        <div class="ctrl-row"><span>🔍 Zoom speed</span><input type="range" id="zoomSpeed" min="0.5" max="3.0" step="0.1" value="1.0"><span id="zoomVal">1.0</span></div>
        <div class="ctrl-row"><button id="resetViewBtn">🎯 Reset View</button></div>
        <div class="ctrl-row"><span style="font-size:9px;">Settings logged</span></div>
    </div>
    <button id="debug-toggle">[+] Logs</button>
    <div id="debug-panel"></div>
    <div id="readme-panel"><span id="close-readme">✖</span><div id="readme-content"></div></div>

    <script type="module">
        import * as THREE from 'three';
        import { OrbitControls } from 'three/addons/controls/OrbitControls.js';
        import { CSS2DRenderer, CSS2DObject } from 'three/addons/renderers/CSS2DRenderer.js';

        // ==================== LOGGING (CORE PRINCIPLE) ====================
        // CITATION: "Capture raw, verbatim output from the source, displayed live in your terminal."
        // Source: audit_0011.sh line 21‑point checklist (skills_0008.md)
        let terminalLoggingEnabled = false;
        async function logEvent(level, event, data = {}) {
            const entry = { timestamp: new Date().toISOString(), level, event, data, url: window.location.href };
            console.log(JSON.stringify(entry));
            const panel = document.getElementById('debug-panel');
            if (panel && panel.style.display !== 'none') {
                const div = document.createElement('div');
                div.textContent = `[${new Date().toLocaleTimeString()}] ${level.toUpperCase()} ${event} ${JSON.stringify(data)}`;
                panel.appendChild(div);
                panel.scrollTop = panel.scrollHeight;
                while (panel.children.length > 500) panel.removeChild(panel.children[0]);
            }
            if (terminalLoggingEnabled) {
                try {
                    await fetch('/log', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(entry) });
                } catch(e) {}
            }
        }
        function evidenceLog(msg) { logEvent('info', 'evidence', { message: msg }); }

        (async () => {
            try {
                const res = await fetch('/log', { method: 'OPTIONS' });
                if (res.ok || res.status === 404) terminalLoggingEnabled = true;
            } catch(e) {}
        })();

        // Toggle debug panel
        const toggleBtn = document.getElementById('debug-toggle');
        const debugPanel = document.getElementById('debug-panel');
        if (toggleBtn && debugPanel) {
            debugPanel.style.display = 'none';
            toggleBtn.onclick = () => {
                const isHidden = debugPanel.style.display === 'none';
                debugPanel.style.display = isHidden ? 'block' : 'none';
                toggleBtn.textContent = isHidden ? '[-] Logs' : '[+] Logs';
                logEvent('info', 'debug_toggle', { display: debugPanel.style.display });
            };
        }
        evidenceLog('[C1] Starting application');

        // ==================== SELF-TEST ====================
        let selfTestResults = [];
        function assertTest(condition, name, details = {}) {
            if (condition) {
                logEvent('info', 'test_pass', { test: name, details });
                selfTestResults.push({ test: name, status: 'PASS', details });
            } else {
                logEvent('error', 'test_fail', { test: name, details });
                selfTestResults.push({ test: name, status: 'FAIL', details });
            }
        }
        function runSelfTest() {
            logEvent('info', 'self_test_start', {});
            assertTest(typeof THREE !== 'undefined', 'THREE loaded');
            assertTest(typeof OrbitControls !== 'undefined', 'OrbitControls loaded');
            assertTest(typeof CSS2DRenderer !== 'undefined', 'CSS2DRenderer loaded');
            assertTest(document.getElementById('minimap-container') !== null, 'Minimap exists');
            assertTest(document.getElementById('control-panel') !== null, 'Control panel exists');
            assertTest(document.getElementById('similarBtn') !== null, 'Similar button exists');
            assertTest(document.getElementById('fuzzySearchInput') !== null, 'Fuzzy search exists');
            assertTest(document.getElementById('searchInput') !== null, 'Search input exists');
            logEvent('info', 'self_test_complete', { pass: selfTestResults.filter(r => r.status === 'PASS').length, total: selfTestResults.length });
        }

        // ==================== GITHUB API (NO MOCK) ====================
        // CITATION: "If an API call fails, log the error and stop; do not substitute mock data." (T025)
        let repoMetadata = []; // store { name, description } for searching

        async function fetchRealRepos() {
            const url = 'https://api.github.com/users/swipswaps/repos?per_page=100&sort=updated&type=public';
            logEvent('info', 'github_api_fetch', { url });
            try {
                const resp = await fetch(url);
                const rateLimit = resp.headers.get('X-RateLimit-Remaining');
                logEvent('info', 'github_api_response', { status: resp.status, ratelimit_remaining: rateLimit });
                if (!resp.ok) throw new Error(`HTTP ${resp.status}`);
                const repos = await resp.json();
                logEvent('info', 'github_api_count', { count: repos.length });
                repoMetadata = repos.map(r => ({ name: r.name, description: r.description || '' }));
                return repos;
            } catch(err) { logEvent('error', 'github_api_exception', { message: err.message }); return null; }
        }

        // ==================== README FETCH (UTF-8 SAFE) ====================
        async function fetchReadme(repoName) {
            const url = `https://api.github.com/repos/swipswaps/${repoName}/readme`;
            try {
                const resp = await fetch(url);
                if (!resp.ok) return "README not available.";
                const data = await resp.json();
                const binary = atob(data.content);
                const bytes = Uint8Array.from(binary, c => c.charCodeAt(0));
                const text = new TextDecoder('utf-8').decode(bytes);
                const safeText = text.substring(0, 500).replace(/[&<>]/g, (m) => {
                    if (m === '&') return '&amp;';
                    if (m === '<') return '&lt;';
                    if (m === '>') return '&gt;';
                    return m;
                });
                return safeText + (text.length > 500 ? "..." : "");
            } catch(e) { return "Error loading README."; }
        }

        // ==================== SIMILARITY & CHAT LOG SEARCH ====================
        // CITATION: T015 Component Decomposition – each part has its own log line
        let similarityData = null;
        async function loadSimilarityData() {
            try {
                const response = await fetch('./similarity.json');
                if (!response.ok) throw new Error(`HTTP ${response.status}`);
                similarityData = await response.json();
                logEvent('info', 'similarity_data_loaded', { repos: Object.keys(similarityData).length });
            } catch (err) {
                logEvent('error', 'similarity_data_failed', { message: err.message });
                similarityData = null;
            }
        }

        // ==================== ENHANCED SEARCH (name + description + chat logs) ====================
        // CITATION: T003 Marker‑Based Verification – we use marker strings to test search later
        function filterRepos() {
            const query = document.getElementById('searchInput').value.trim().toLowerCase();
            logEvent('user_action', 'filter', { query });
            let visible = 0;
            document.querySelectorAll('.repo-label').forEach(label => {
                const repoName = label.textContent;
                const meta = repoMetadata.find(m => m.name === repoName);
                const desc = meta ? meta.description.toLowerCase() : '';
                const chatSnippet = (similarityData && similarityData[repoName]) ? JSON.stringify(similarityData[repoName]).toLowerCase() : '';
                if (repoName.toLowerCase().includes(query) || desc.includes(query) || chatSnippet.includes(query)) {
                    label.style.display = 'block';
                    visible++;
                } else {
                    label.style.display = 'none';
                }
            });
            logEvent('info', 'filter_result', { visible });
        }

        function fuzzySearchRepos() {
            const query = document.getElementById('fuzzySearchInput').value.trim().toLowerCase();
            logEvent('user_action', 'fuzzy_search', { query });
            if (!query) {
                document.querySelectorAll('.repo-label').forEach(lbl => lbl.style.display = 'block');
                return;
            }
            let visible = 0;
            document.querySelectorAll('.repo-label').forEach(label => {
                const repoName = label.textContent;
                const meta = repoMetadata.find(m => m.name === repoName);
                const desc = meta ? meta.description.toLowerCase() : '';
                const chatSnippet = (similarityData && similarityData[repoName]) ? JSON.stringify(similarityData[repoName]).toLowerCase() : '';
                if (repoName.toLowerCase().includes(query) || desc.includes(query) || chatSnippet.includes(query)) {
                    label.style.display = 'block';
                    visible++;
                } else {
                    label.style.display = 'none';
                }
            });
            logEvent('info', 'fuzzy_search_result', { query, visible });
        }

        // ==================== THREE.JS ====================
        // (All existing Three.js code remains unchanged – minimap, controls, raycasting, etc.)
        async function initThree() {
            const repos = await fetchRealRepos();
            if (!repos) { evidenceLog('❌ Failed to load repos'); return; }

            const scene = new THREE.Scene();
            scene.background = new THREE.Color(0x050510);
            scene.fog = new THREE.FogExp2(0x050510, 0.008);
            const camera = new THREE.PerspectiveCamera(45, window.innerWidth / window.innerHeight, 0.1, 1000);
            camera.position.set(15, 10, 20);
            const renderer = new THREE.WebGLRenderer({ antialias: true });
            renderer.setSize(window.innerWidth, window.innerHeight);
            document.body.appendChild(renderer.domElement);

            const labelRenderer = new CSS2DRenderer();
            labelRenderer.setSize(window.innerWidth, window.innerHeight);
            labelRenderer.domElement.style.position = 'absolute';
            labelRenderer.domElement.style.top = '0px';
            labelRenderer.domElement.style.left = '0px';
            labelRenderer.domElement.style.pointerEvents = 'none';
            document.body.appendChild(labelRenderer.domElement);

            // Minimap (desktop only)
            const minimapCanvas = document.getElementById('minimap-canvas');
            let minimapRenderer, minimapCamera;
            if (minimapCanvas && window.innerWidth > 768) {
                minimapCanvas.width = 180;
                minimapCanvas.height = 180;
                minimapRenderer = new THREE.WebGLRenderer({ canvas: minimapCanvas, alpha: true });
                minimapRenderer.setSize(180, 180);
                minimapRenderer.setClearColor(0x050510, 0.8);
                minimapCamera = new THREE.OrthographicCamera(-10, 10, 10, -10, 0.1, 50);
                minimapCamera.position.set(0, 20, 0);
                minimapCamera.lookAt(0, 0, 0);
                const minimapAmbient = new THREE.AmbientLight(0x404040);
                scene.add(minimapAmbient);
                const minimapLight = new THREE.DirectionalLight(0xffffff, 1.2);
                minimapLight.position.set(1, 2, 1);
                scene.add(minimapLight);
            }

            const controls = new OrbitControls(camera, renderer.domElement);
            controls.enableDamping = true;
            controls.dampingFactor = 0.1;
            controls.autoRotate = false;
            controls.autoRotateSpeed = 0.8;
            controls.enableZoom = true;
            controls.enablePan = true;
            controls.rotateSpeed = 1.0;
            controls.zoomSpeed = 1.0;
            controls.target.set(0, 0, 0);

            // Control panel (same as before)
            const ctrlToggle = document.getElementById('ctrl-toggle');
            const ctrlPanel = document.getElementById('control-panel');
            if (ctrlToggle && ctrlPanel) {
                ctrlToggle.onclick = () => {
                    const isHidden = ctrlPanel.style.display === 'none';
                    ctrlPanel.style.display = isHidden ? 'block' : 'none';
                    logEvent('info', 'control_panel_toggle', { visible: isHidden });
                };
                ctrlPanel.style.display = 'none';
            }
            const initialCameraPos = camera.position.clone();
            const initialControlsTarget = controls.target.clone();
            const autoRotateBtn = document.getElementById('toggleAutoRotate');
            const dampingBtn = document.getElementById('toggleDamping');
            const dampingSlider = document.getElementById('dampingFactor');
            const dampingVal = document.getElementById('dampingVal');
            const rotSlider = document.getElementById('rotateSpeed');
            const rotVal = document.getElementById('rotateVal');
            const zoomSlider = document.getElementById('zoomSpeed');
            const zoomVal = document.getElementById('zoomVal');
            const resetBtn = document.getElementById('resetViewBtn');
            if (autoRotateBtn) autoRotateBtn.onclick = () => { controls.autoRotate = !controls.autoRotate; autoRotateBtn.textContent = controls.autoRotate ? 'ON' : 'OFF'; logEvent('user_action', 'auto_rotate_toggle', { state: controls.autoRotate }); };
            if (dampingBtn) dampingBtn.onclick = () => { controls.enableDamping = !controls.enableDamping; dampingBtn.textContent = controls.enableDamping ? 'ON' : 'OFF'; logEvent('user_action', 'damping_toggle', { state: controls.enableDamping }); };
            if (dampingSlider) dampingSlider.oninput = () => { const val = parseFloat(dampingSlider.value); controls.dampingFactor = val; dampingVal.textContent = val.toFixed(2); logEvent('user_action', 'damping_factor_change', { value: val }); };
            if (rotSlider) rotSlider.oninput = () => { const val = parseFloat(rotSlider.value); controls.rotateSpeed = val; rotVal.textContent = val.toFixed(1); logEvent('user_action', 'rotate_speed_change', { value: val }); };
            if (zoomSlider) zoomSlider.oninput = () => { const val = parseFloat(zoomSlider.value); controls.zoomSpeed = val; zoomVal.textContent = val.toFixed(1); logEvent('user_action', 'zoom_speed_change', { value: val }); };
            if (resetBtn) resetBtn.onclick = () => { camera.position.copy(initialCameraPos); controls.target.copy(initialControlsTarget); controls.update(); logEvent('user_action', 'reset_view', { position: camera.position, target: controls.target }); };
            controls.addEventListener('start', () => { if (controls.autoRotate) { controls.autoRotate = false; if (autoRotateBtn) autoRotateBtn.textContent = 'OFF'; logEvent('user_action', 'auto_rotate_disabled_by_drag', {}); } });

            const raycaster = new THREE.Raycaster();
            const mouse = new THREE.Vector2();
            let lastHoveredRepo = null;
            const cloudGroup = new THREE.Group();
            scene.add(cloudGroup);

            const readmePanel = document.getElementById('readme-panel');
            const readmeContent = document.getElementById('readme-content');
            const closeReadme = document.getElementById('close-readme');
            if (closeReadme) closeReadme.onclick = () => readmePanel.style.display = 'none';

            // Click handler (canvas-scoped, T026)
            renderer.domElement.addEventListener('click', async (event) => {
                const rect = renderer.domElement.getBoundingClientRect();
                mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
                mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
                raycaster.setFromCamera(mouse, camera);
                let intersects = raycaster.intersectObjects(cloudGroup.children.filter(c => c.isMesh));
                let repoName = null;
                if (intersects.length > 0) repoName = intersects[0].object.userData.name;
                else if (lastHoveredRepo) { repoName = lastHoveredRepo; logEvent('debug', 'click_fallback_to_hover', { repo: repoName }); }
                if (repoName) {
                    window._lastClickedRepo = repoName;
                    logEvent('user_action', 'click_repository', { repo: repoName });
                    const sphere = cloudGroup.children.find(c => c.isMesh && c.userData.name === repoName);
                    if (sphere) {
                        sphere.material.emissive.setHex(0xffaa00);
                        setTimeout(() => sphere.material.emissive.setHex(0x1a4d40), 500);
                    }
                    readmeContent.innerHTML = "Loading README...";
                    readmePanel.style.display = 'block';
                    const readmeText = await fetchReadme(repoName);
                    readmeContent.innerHTML = `<strong>${repoName}</strong><br><br>${readmeText.replace(/\n/g, '<br>')}<br><br><a href="https://github.com/swipswaps/${repoName}" target="_blank">Open on GitHub →</a>`;
                } else {
                    logEvent('debug', 'click_canvas_empty', { clientX: event.clientX, clientY: event.clientY });
                }
            });

            // Double-click (native, T032)
            renderer.domElement.addEventListener('dblclick', async (event) => {
                const rect = renderer.domElement.getBoundingClientRect();
                mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
                mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
                raycaster.setFromCamera(mouse, camera);
                let intersects = raycaster.intersectObjects(cloudGroup.children.filter(c => c.isMesh));
                let repoName = null;
                if (intersects.length > 0) repoName = intersects[0].object.userData.name;
                else if (lastHoveredRepo) { repoName = lastHoveredRepo; logEvent('debug', 'double_click_fallback_to_hover', { repo: repoName }); }
                if (repoName) {
                    logEvent('user_action', 'double_click_repository', { repo: repoName });
                    window.open(`https://github.com/swipswaps/${repoName}`, '_blank', 'noopener,noreferrer');
                }
            });

            // Hover with RAF (T031)
            let rafId = null;
            renderer.domElement.addEventListener('mousemove', (event) => {
                if (rafId) return;
                rafId = requestAnimationFrame(() => {
                    const rect = renderer.domElement.getBoundingClientRect();
                    mouse.x = ((event.clientX - rect.left) / rect.width) * 2 - 1;
                    mouse.y = -((event.clientY - rect.top) / rect.height) * 2 + 1;
                    raycaster.setFromCamera(mouse, camera);
                    const intersects = raycaster.intersectObjects(cloudGroup.children.filter(c => c.isMesh));
                    if (intersects.length > 0) {
                        const repoName = intersects[0].object.userData.name;
                        if (lastHoveredRepo !== repoName) {
                            lastHoveredRepo = repoName;
                            logEvent('debug', 'hover_repository', { repo: repoName });
                        }
                    } else {
                        lastHoveredRepo = null;
                    }
                    rafId = null;
                });
            });

            const ambientLight = new THREE.AmbientLight(0x404040);
            scene.add(ambientLight);
            const dirLight = new THREE.DirectionalLight(0xffffff, 1);
            dirLight.position.set(1, 2, 1);
            scene.add(dirLight);

            function hashCode(str) {
                let hash = 0;
                for (let i = 0; i < str.length; i++) {
                    hash = ((hash << 5) - hash) + str.charCodeAt(i);
                    hash |= 0;
                }
                return hash;
            }
            const isTouch = ('ontouchstart' in window) || (navigator.maxTouchPoints > 0);
            const sphereRadius = isTouch ? 0.7 : 0.5;
            repos.forEach(repo => {
                const hue = ((Math.abs(hashCode(repo.name)) % 360) / 360);
                const color = new THREE.Color().setHSL(hue, 0.8, 0.5);
                const material = new THREE.MeshStandardMaterial({ color });
                const sphere = new THREE.Mesh(new THREE.SphereGeometry(sphereRadius, 16, 16), material);
                const phi = Math.acos(2 * Math.random() - 1);
                const theta = 2 * Math.PI * Math.random();
                const radius = 8;
                sphere.position.x = radius * Math.sin(phi) * Math.cos(theta);
                sphere.position.y = radius * Math.sin(phi) * Math.sin(theta);
                sphere.position.z = radius * Math.cos(phi);
                sphere.userData = { name: repo.name };

                const div = document.createElement('div');
                div.textContent = repo.name.length > 25 ? repo.name.substring(0,22)+'...' : repo.name;
                div.style.cssText = 'color:#5effe0;font-size:12px;font-family:monospace;background:rgba(0,0,0,0.7);padding:4px 8px;border-radius:20px;border:1px solid #5effe0;white-space:nowrap;';
                div.className = 'repo-label';
                div.style.pointerEvents = 'none';
                const label = new CSS2DObject(div);
                label.position.copy(sphere.position);
                cloudGroup.add(sphere);
                cloudGroup.add(label);
            });

            evidenceLog(`✅ Rendered ${repos.length} real repos`);
            evidenceLog('🎨 App ready: search includes descriptions & chat logs');

            // Wire search buttons (enhanced)
            const searchInput = document.getElementById('searchInput');
            const searchBtn = document.getElementById('searchBtn');
            const clearBtn = document.getElementById('clearBtn');
            const fuzzyInput = document.getElementById('fuzzySearchInput');
            const similarBtn = document.getElementById('similarBtn');

            if (clearBtn) clearBtn.onclick = () => { if(searchInput) searchInput.value=''; if(fuzzyInput) fuzzyInput.value=''; document.querySelectorAll('.repo-label').forEach(lbl=>lbl.style.display='block'); logEvent('user_action','clear_filter',{}); };
            if (searchBtn) searchBtn.onclick = filterRepos;
            if (searchInput) searchInput.addEventListener('keypress', (e) => { if(e.key === 'Enter') filterRepos(); });
            if (fuzzyInput) fuzzyInput.addEventListener('input', fuzzySearchRepos);

            // Similarity button (unchanged)
            if (similarBtn) {
                similarBtn.onclick = () => {
                    if (window._lastClickedRepo) drawSimilarityLines(window._lastClickedRepo);
                    else alert('Click a repository first');
                };
            }

            await loadSimilarityData();
            runSelfTest();

            function animate() {
                requestAnimationFrame(animate);
                controls.update();
                renderer.render(scene, camera);
                labelRenderer.render(scene, camera);
                if (minimapRenderer && minimapCamera) minimapRenderer.render(scene, minimapCamera);
            }
            animate();
        }

        initThree();
    </script>
</body>
</html>
