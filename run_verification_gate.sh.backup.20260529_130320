#!/bin/bash
# No manual steps – everything scripted

echo "========================================="
echo " LLM Evasion Detection Gate"
echo "========================================="

exit_code=0

# 1. Static checks
bash test_static.sh || exit_code=1

# 2. Detectors
bash verification/check_fake_citations.sh || exit_code=1
bash verification/check_terminal_logging.sh || exit_code=1
bash verification/check_features_not_removed.sh || exit_code=1
bash verification/check_no_regex_breakage.sh || exit_code=1
bash verification/check_search_works.sh || exit_code=1

# 3. Warning only
if grep -q similarBtn index.html && [ ! -f similarity.json ]; then
    echo "⚠️  Warning: similarBtn exists but similarity.json is missing."
fi

# 4. Automatically start server_with_logs.py and verify self‑test
echo ""
echo "Starting server_with_logs.py in background..."
python3 server_with_logs.py > /tmp/server_logs.txt 2>&1 &
SERVER_PID=$!

# Wait for server to start
sleep 2

# Open browser (optional – but scripted)
if command -v xdg-open >/dev/null 2>&1; then
    xdg-open http://localhost:8765 2>/dev/null &
fi

# Wait for self‑test completion (look for "self_test_complete" in server logs)
echo "Waiting for self‑test to complete (max 60 seconds)..."
TIMEOUT=60
for i in $(seq 1 $TIMEOUT); do
    if grep -q "self_test_complete" /tmp/server_logs.txt 2>/dev/null; then
        echo "✅ Self‑test completed."
        # Check if any test failed
        if grep -q "test_fail" /tmp/server_logs.txt; then
            echo "❌ Self‑test failures detected:"
            grep "test_fail" /tmp/server_logs.txt
            exit_code=1
        else
            echo "✅ All self‑tests passed."
        fi
        break
    fi
    sleep 1
    if [ $i -eq $TIMEOUT ]; then
        echo "❌ Timeout waiting for self‑test completion."
        exit_code=1
    fi
done

# Kill the server
kill $SERVER_PID 2>/dev/null || true

# 5. Deployment check (only if git repo exists)
if git rev-parse --verify HEAD >/dev/null 2>&1; then
    bash verification/check_deployment_sha256_match.sh || exit_code=1
fi

if [ $exit_code -eq 0 ]; then
    echo "========================================="
    echo " All checks passed. Ready to commit/push."
    echo "========================================="
else
    echo "========================================="
    echo " Some checks failed. Fix above issues."
    echo "========================================="
    exit 1
fi
